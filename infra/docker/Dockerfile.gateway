FROM node:20-alpine

WORKDIR /app

RUN apk add --no-cache curl

COPY package.json ./
RUN npm install --omit=dev

COPY src ./src

ENV PORT=3000
EXPOSE 3000

# Install nodemon for optional hot-reload in development mode
RUN npm install -g nodemon

# Use nodemon if DEV_MODE is set; otherwise run normally
CMD ["sh", "-c", "if [ \"$DEV_MODE\" = \"true\" ]; then nodemon --watch src --delay 1 --exec \"npm run start:gateway\"; else npm run start:gateway; fi"]