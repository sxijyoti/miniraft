# Environment Configuration (Machine Independent)
# Copy this file to .env and adjust values as needed

# Gateway Configuration
GATEWAY_PORT=3000
GATEWAY_HOST=0.0.0.0

# Replica Configuration
REPLICA1_PORT=4001
REPLICA1_ID=1

REPLICA2_PORT=4002
REPLICA2_ID=2

REPLICA3_PORT=4003
REPLICA3_ID=3

# Network Configuration (Internal to Docker)
# Use container names for inter-container communication
REPLICA1_URL=http://replica1:4001
REPLICA2_URL=http://replica2:4002
REPLICA3_URL=http://replica3:4003
GATEWAY_URL=http://gateway:3000

# Logging
DEBUG=false
# Set to 'true' for verbose RAFT logging
# Set to 'raft' for RAFT-specific debug logs only

# Node Environment
NODE_ENV=development
